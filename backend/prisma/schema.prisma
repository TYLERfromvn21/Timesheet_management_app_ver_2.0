// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 1. Model Auth ---
model User {
  id            String       @id @default(cuid())
  username      String       @unique
  password      String
  role          UserRole
  isUnlocked    Boolean?
  departments   Department[] @relation("NewRelation") 
  departmentId  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([role])
}

model Department {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  
  users     User[]    @relation("NewRelation") 

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// --- 2. Model Dashboard ---
model JobCode {
  id              String   @id @default(uuid())
  department      String   
  jobCode         String   @unique
  taskDescription String
  createdAt       DateTime @default(now())
  isDeleted       Boolean  @default(false)
}

model Task {
  id              String   @id @default(uuid())
  department      String
  jobCode         String
  taskDescription String
  startTime       DateTime
  endTime         DateTime
  date            DateTime 
  createdAt       DateTime @default(now())
  userId          String
}

model DeclarationSetting {
  id            Int              @id @default(1)
  mode          DeclarationMode  @default(LOCKED)
  specificDate  DateTime?
  updatedBy     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// --- 3. Enums ---
enum UserRole {
  ADMIN_TOTAL
  ADMIN_DEPT
  USER
}

enum DeclarationMode {
  LOCKED
  OPEN_ALL
  OPEN_DATE
}
